<script>
  let currentStep = 1;

  function showStep(step: number) {
    document.querySelectorAll('.audit-step').forEach(s => s.classList.remove('active'));
    const target = document.querySelector(`.audit-step[data-step="${step}"]`);
    if (target) target.classList.add('active');
    document.querySelectorAll('.audit-progress-dot').forEach(d => {
      const el = d as HTMLElement;
      el.classList.toggle('active', parseInt(el.dataset.step || '0') <= step);
    });
    const label = document.getElementById('stepLabel');
    if (label) label.textContent = `Step ${step} of 4`;
    currentStep = step;
  }

  function validateStep(step: number): boolean {
    let valid = true;
    const stepEl = document.querySelector(`.audit-step[data-step="${step}"]`);
    if (!stepEl) return false;
    const requiredFields = stepEl.querySelectorAll('[required]');

    requiredFields.forEach(field => {
      const input = field as HTMLInputElement;
      const group = input.closest('.form-group');
      if (!input.value.trim()) {
        group?.classList.add('has-error');
        valid = false;
      } else if (input.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
        group?.classList.add('has-error');
        valid = false;
      } else {
        group?.classList.remove('has-error');
      }
    });

    return valid;
  }

  // Next buttons
  document.querySelectorAll('.form-next[data-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = parseInt((btn as HTMLElement).dataset.next || '0');
      if (!validateStep(currentStep)) return;
      showStep(next);
    });
  });

  // Back buttons
  document.querySelectorAll('.form-back[data-back]').forEach(btn => {
    btn.addEventListener('click', () => {
      const back = parseInt((btn as HTMLElement).dataset.back || '0');
      showStep(back);
    });
  });

  // Clear errors on input
  document.querySelectorAll('.audit-step input, .audit-step select, .audit-step textarea').forEach(field => {
    field.addEventListener('input', () => {
      field.closest('.form-group')?.classList.remove('has-error');
    });
    field.addEventListener('change', () => {
      field.closest('.form-group')?.classList.remove('has-error');
    });
  });

  // Listen for hero skip-to-step event
  window.addEventListener('audit-skip-to-step', ((e: CustomEvent) => {
    showStep(e.detail);
  }) as EventListener);

  // Submit
  document.getElementById('auditSubmitBtn')?.addEventListener('click', async () => {
    if (!validateStep(4)) return;

    const formData = {
      name: (document.getElementById('audit-name') as HTMLInputElement).value,
      email: (document.getElementById('audit-email') as HTMLInputElement).value,
      phone: (document.getElementById('audit-phone') as HTMLInputElement).value,
      website: (document.getElementById('audit-website') as HTMLInputElement).value,
      industry: (document.getElementById('audit-industry') as HTMLInputElement).value,
      team_size: (document.getElementById('audit-team') as HTMLSelectElement).value,
      challenge: (document.getElementById('audit-challenge') as HTMLTextAreaElement).value,
      time_area: (document.getElementById('audit-area') as HTMLSelectElement).value,
      hours_per_week: parseFloat((document.getElementById('audit-hours') as HTMLSelectElement).value),
      hourly_value: parseFloat((document.getElementById('audit-value') as HTMLInputElement).value) || 75,
    };

    // Hide form, show loading
    document.querySelectorAll('.audit-step').forEach(s => s.classList.remove('active'));
    const progress = document.getElementById('auditProgress');
    const label = document.getElementById('stepLabel');
    if (progress) progress.style.display = 'none';
    if (label) label.style.display = 'none';
    document.getElementById('auditLoading')?.classList.add('active');

    try {
      const response = await fetch('/api/analyze', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData),
      });

      if (!response.ok) throw new Error('API error');

      const data = await response.json();
      renderResults(data);
    } catch {
      renderFallback(formData);
    }
  });

  function renderResults(data: { ideas: Array<{ title: string; description: string; hours_saved_per_week: number }>; total_annual_savings: string; total_hours_saved_per_year: string }) {
    document.getElementById('auditLoading')?.classList.remove('active');

    const ideasContainer = document.getElementById('auditIdeas');
    if (!ideasContainer) return;
    ideasContainer.innerHTML = '';

    data.ideas.forEach(idea => {
      const ideaEl = document.createElement('div');
      ideaEl.className = 'result-idea';
      ideaEl.innerHTML = `
        <h4>${idea.title}</h4>
        <p>${idea.description}</p>
        <span class="time-saved">${idea.hours_saved_per_week}h saved per week</span>
      `;
      ideasContainer.appendChild(ideaEl);
    });

    const savings = document.getElementById('auditSavings');
    const hours = document.getElementById('auditHoursSaved');
    if (savings) savings.textContent = data.total_annual_savings;
    if (hours) hours.textContent = data.total_hours_saved_per_year;

    document.getElementById('auditResults')?.classList.add('active');
  }

  function renderFallback(formData: { hours_per_week: number; hourly_value: number }) {
    document.getElementById('auditLoading')?.classList.remove('active');

    const ideasContainer = document.getElementById('auditIdeas');
    if (ideasContainer) {
      ideasContainer.innerHTML = `
        <div class="result-idea">
          <p style="color:rgba(255,255,255,0.7)">We've captured your details and will be in touch within 24 hours with your personalised automation audit.</p>
        </div>
      `;
    }

    const weeklySavings = formData.hours_per_week * 0.6;
    const annualSavings = Math.round(weeklySavings * formData.hourly_value * 48);
    const savings = document.getElementById('auditSavings');
    const hours = document.getElementById('auditHoursSaved');
    if (savings) savings.textContent = `\u00A3${annualSavings.toLocaleString()}`;
    if (hours) hours.textContent = `Based on ${Math.round(weeklySavings * 48)} hours recovered per year`;

    document.getElementById('auditResults')?.classList.add('active');
  }
</script>
