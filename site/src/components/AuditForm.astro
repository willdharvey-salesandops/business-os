<section class="section-audit" id="audit">
  <div class="container">
    <p class="eyebrow reveal">Free in 60 Seconds</p>
    <h2 class="reveal" style="margin-bottom:1rem;">How much is your business losing to manual work?</h2>
    <p class="audit-intro reveal">Drop in your website and answer three quick questions. We'll show you exactly what to automate and how much you'd save this year.</p>

    <div class="audit-grid">
      <div class="audit-copy reveal">
        <ul class="audit-selling-points">
          <li>
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Personalised to your business, not generic advice</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>See your estimated annual savings in pounds</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>Results generated instantly by AI. No waiting for a callback.</span>
          </li>
          <li>
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"></polyline></svg>
            <span>No commitment. Just clarity on what's possible.</span>
          </li>
        </ul>
      </div>

      <div class="audit-form-container reveal">
        <div class="audit-progress" id="auditProgress">
          <span class="audit-progress-dot active" data-step="1"></span>
          <span class="audit-progress-dot" data-step="2"></span>
          <span class="audit-progress-dot" data-step="3"></span>
          <span class="audit-progress-dot" data-step="4"></span>
        </div>
        <p class="audit-step-label" id="stepLabel">Step 1 of 4</p>

        <!-- Step 1: You -->
        <div class="audit-step active" data-step="1">
          <h3>About you</h3>
          <div class="form-group">
            <label for="audit-name">First name</label>
            <input type="text" id="audit-name" placeholder="Jane" required>
            <p class="form-error">Please enter your name.</p>
          </div>
          <div class="form-group">
            <label for="audit-email">Email</label>
            <input type="email" id="audit-email" placeholder="jane@company.com" required>
            <p class="form-error">Please enter a valid email.</p>
          </div>
          <div class="form-group">
            <label for="audit-phone">Phone (optional)</label>
            <input type="tel" id="audit-phone" placeholder="+44 7700 900000">
          </div>
          <div class="form-nav">
            <button type="button" class="form-next" data-next="2">Next</button>
          </div>
        </div>

        <!-- Step 2: Your Business -->
        <div class="audit-step" data-step="2">
          <h3>Your business</h3>
          <div class="form-group">
            <label for="audit-website">Website or domain</label>
            <input type="url" id="audit-website" placeholder="https://yourcompany.com" required>
            <p class="form-error">Please enter your website address.</p>
          </div>
          <div class="form-group">
            <label for="audit-industry">What does your business do?</label>
            <input type="text" id="audit-industry" placeholder="e.g. Accounting firm, SaaS product, Recruitment" required>
            <p class="form-error">Please describe your business.</p>
          </div>
          <div class="form-group">
            <label for="audit-team">Team size</label>
            <select id="audit-team" required>
              <option value="">Select...</option>
              <option value="1-5">1 - 5 people</option>
              <option value="6-10">6 - 10 people</option>
              <option value="11-20">11 - 20 people</option>
              <option value="20+">20+ people</option>
            </select>
            <p class="form-error">Please select your team size.</p>
          </div>
          <div class="form-nav">
            <button type="button" class="form-back" data-back="1">&larr; Back</button>
            <button type="button" class="form-next" data-next="3">Next</button>
          </div>
        </div>

        <!-- Step 3: The Problem -->
        <div class="audit-step" data-step="3">
          <h3>The bottleneck</h3>
          <div class="form-group">
            <label for="audit-challenge">What's the biggest operational challenge right now?</label>
            <textarea id="audit-challenge" placeholder="e.g. We spend hours chasing invoices, onboarding is all manual, leads fall through the cracks..." required></textarea>
            <p class="form-error">Please describe your challenge.</p>
          </div>
          <div class="form-group">
            <label for="audit-area">What takes up most of your time?</label>
            <select id="audit-area" required>
              <option value="">Select...</option>
              <option value="Sales & lead generation">Sales &amp; lead generation</option>
              <option value="Admin & operations">Admin &amp; operations</option>
              <option value="Client delivery">Client delivery</option>
              <option value="Hiring & onboarding">Hiring &amp; onboarding</option>
              <option value="Content & marketing">Content &amp; marketing</option>
            </select>
            <p class="form-error">Please select an area.</p>
          </div>
          <div class="form-nav">
            <button type="button" class="form-back" data-back="2">&larr; Back</button>
            <button type="button" class="form-next" data-next="4">Next</button>
          </div>
        </div>

        <!-- Step 4: The Cost -->
        <div class="audit-step" data-step="4">
          <h3>The cost</h3>
          <div class="form-group">
            <label for="audit-hours">How many hours per week does this cost you?</label>
            <select id="audit-hours" required>
              <option value="">Select...</option>
              <option value="3">2 - 5 hours</option>
              <option value="7">5 - 10 hours</option>
              <option value="15">10 - 20 hours</option>
              <option value="25">20+ hours</option>
            </select>
            <p class="form-error">Please select an estimate.</p>
          </div>
          <div class="form-group">
            <label for="audit-value">Estimated hourly value of your time (&pound;)</label>
            <input type="number" id="audit-value" placeholder="75" min="1">
          </div>
          <div class="form-nav">
            <button type="button" class="form-back" data-back="3">&larr; Back</button>
            <button type="button" class="form-next form-submit" id="auditSubmitBtn">Get My Free Results</button>
          </div>
        </div>

        <!-- Loading -->
        <div class="audit-loading" id="auditLoading">
          <div class="audit-spinner"></div>
          <p>Analysing your business...</p>
        </div>

        <!-- Results -->
        <div class="audit-results" id="auditResults">
          <h3>Here's what we'd build for you.</h3>
          <div id="auditIdeas"></div>
          <div class="result-total">
            <p class="result-total-label">Estimated Annual Savings</p>
            <p class="result-total-number" id="auditSavings"></p>
            <p class="result-total-sub" id="auditHoursSaved"></p>
          </div>
          <div class="result-cta">
            <a href="https://calendly.com/will-leadershipgrowthconsulting/30min" target="_blank" rel="noopener" class="btn-primary">Book a Call to Discuss These Ideas</a>
            <p class="result-footnote">No pitch. Just a straight conversation about what we could build together.</p>
            <p class="result-footnote result-email-note">We've also emailed you a PDF with your full results. If you don't see it, check your spam folder.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider"></div>

