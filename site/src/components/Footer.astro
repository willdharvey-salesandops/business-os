---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <p>&copy; {year} Leadership Growth Consulting</p>
    <p class="footer-email">
      <a href="mailto:will@leadershipgrowthconsulting.com">will@leadershipgrowthconsulting.com</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: 3rem 0;
    text-align: center;
    border-top: 1px solid var(--grey-200);
  }

  .footer p {
    font-size: 0.82rem;
    color: var(--grey-400);
  }

  .footer a {
    color: var(--grey-400);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer a:hover {
    color: var(--teal);
  }

  .footer-email {
    margin-top: 0.5rem;
  }
</style>
