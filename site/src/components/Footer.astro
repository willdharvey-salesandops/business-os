---
const year = new Date().getFullYear();
---

<footer class="bg-zinc-900 py-14">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between gap-10 mb-12">
      <div>
        <p class="font-serif text-white text-xl mb-1">Will Harvey</p>
        <p class="text-zinc-500 text-sm">Leadership Growth Consulting</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-10">
        <div class="space-y-2">
          <a href="/about" class="block text-zinc-400 hover:text-white text-sm transition-colors">About</a>
          <a href="/work-with-me" class="block text-zinc-400 hover:text-white text-sm transition-colors">Work With Me</a>
          <a href="/results" class="block text-zinc-400 hover:text-white text-sm transition-colors">Results</a>
          <a href="/blog" class="block text-zinc-400 hover:text-white text-sm transition-colors">Blog</a>
          <a href="/contact" class="block text-zinc-400 hover:text-white text-sm transition-colors">Contact</a>
        </div>
        <div>
          <a
            href="mailto:will@leadershipgrowthconsulting.com"
            class="text-zinc-400 hover:text-white text-sm transition-colors"
          >
            will@leadershipgrowthconsulting.com
          </a>
        </div>
      </div>
    </div>
    <div class="border-t border-zinc-800 pt-8">
      <p class="text-zinc-600 text-sm">&copy; {year} Will Harvey. All rights reserved.</p>
    </div>
  </div>
</footer>
