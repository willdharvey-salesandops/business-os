---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import AuditForm from '../../components/AuditForm.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import { marked } from 'marked';

const SUPABASE_URL = import.meta.env.SUPABASE_URL || 'https://zgtaskiordteelfvlmti.supabase.co';
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY || 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpndGFza2lvcmR0ZWVsZnZsbXRpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIzMDk3MDQsImV4cCI6MjA4Nzg4NTcwNH0.wUyyN9GqatrZY3xarbI5qoJMK3RyUPB4-DysF6AxT58';

const { slug } = Astro.params;

let newsletter: any = null;

try {
  const now = new Date().toISOString();
  const res = await fetch(
    `${SUPABASE_URL}/rest/v1/newsletters?slug=eq.${slug}&published=eq.true&published_at=lte.${now}&limit=1`,
    {
      headers: {
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
      },
    }
  );
  if (res.ok) {
    const data = await res.json();
    newsletter = data[0] || null;
  }
} catch (e) {
  // newsletter stays null
}

if (!newsletter) {
  return Astro.redirect('/newsletter');
}

const contentHtml = marked.parse(newsletter.body_markdown || '');

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateISO(dateStr: string) {
  if (!dateStr) return '';
  return new Date(dateStr).toISOString();
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: newsletter.subject,
  author: { '@type': 'Person', name: 'Will Harvey' },
  publisher: { '@type': 'Organization', name: 'Leadership Growth Consulting' },
  url: `https://leadershipgrowthconsulting.com/newsletter/${newsletter.slug}`,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://leadershipgrowthconsulting.com/newsletter/${newsletter.slug}`,
  },
  ...(newsletter.preview_text && { description: newsletter.preview_text }),
  ...(newsletter.published_at && { datePublished: formatDateISO(newsletter.published_at) }),
  ...(newsletter.updated_at && { dateModified: formatDateISO(newsletter.updated_at) }),
};

const title = `${newsletter.subject} | Leadership Growth Consulting`;
const description = newsletter.preview_text || '';
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <Nav />

  <header class="max-w-3xl mx-auto pt-28 pb-6 lg:pt-36 lg:pb-8 px-6 lg:px-8 text-center">
    <p class="text-brand text-xs font-semibold uppercase tracking-wider mb-4">
      Newsletter
    </p>
    <h1 class="font-serif text-3xl lg:text-5xl text-zinc-900 leading-tight mb-5">
      {newsletter.subject}
    </h1>
    <div class="flex items-center justify-center gap-3 text-sm text-zinc-400 flex-wrap">
      <span>Will Harvey</span>
      <span class="w-1 h-1 bg-zinc-300 rounded-full" />
      <span>{formatDate(newsletter.published_at)}</span>
    </div>
  </header>

  <article class="prose max-w-2xl mx-auto px-6 lg:px-8 pb-12" set:html={contentHtml} />

  {newsletter.cta_text && (
    <section class="max-w-2xl mx-auto px-6 lg:px-8 pb-4">
      <p class="text-lg text-zinc-600 leading-relaxed text-center">{newsletter.cta_text}</p>
    </section>
  )}

  <AuditForm />

  <div class="max-w-2xl mx-auto px-6 lg:px-8 pb-16 pt-8">
    <a href="/newsletter" class="text-sm font-medium text-zinc-500 hover:text-zinc-900 uppercase tracking-wider transition-colors">
      &larr; All newsletters
    </a>
  </div>

  <Footer />
  <ScrollReveal />
</Layout>

<style is:global>
  .prose h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2rem;
    font-weight: 500;
    color: #18181b;
    line-height: 1.2;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .prose h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: #18181b;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .prose h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: #18181b;
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose p {
    margin-bottom: 1.25rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #52525b;
  }
  .prose ul, .prose ol {
    margin: 0 0 1.25rem 1.5rem;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #52525b;
  }
  .prose li {
    margin-bottom: 0.35rem;
  }
  .prose blockquote {
    border-left: 3px solid #115e59;
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #18181b;
  }
  .prose a {
    color: #115e59;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose a:hover {
    color: #0d4a46;
  }
  .prose strong {
    color: #18181b;
    font-weight: 600;
  }
  .prose hr {
    border: none;
    border-top: 1px solid #e4e4e7;
    margin: 2rem 0;
  }
</style>
