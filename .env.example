# Business OS — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# ============================================================


# ============================================================
# PROSPEO — List Building
# Used by: List Builder agent
# Get your key at: https://prospeo.io → Account → API
# ============================================================
PROSPEO_API_KEY=your_prospeo_api_key_here


# ============================================================
# INSTANTLY — Sending, Reply Monitoring, Reporting
# Used by: Sending Scheduler, Reply Handler, Reporting agents
# Get your key at: Instantly → Settings → API Keys
# ============================================================
INSTANTLY_API_KEY=your_instantly_api_key_here


# ============================================================
# SENDING ACCOUNTS
# Comma-separated list of sending email addresses.
# Must be warmed up and connected in Instantly.
# ============================================================
SENDING_ACCOUNTS=sender1@yourdomain.com,sender2@yourdomain.com


# ============================================================
# SEND LIMITS
# Max emails per inbox per day. Keep at 30 or below for warmed
# inboxes. Lower for new inboxes (start at 10-15).
# ============================================================
DAILY_SEND_LIMIT_PER_INBOX=30


# ============================================================
# ATTIO — CRM Integration (Placeholder — not yet active)
# Used by: future List Builder, Reply Handler agents
# Get your key at: Attio → Settings → API Keys
# ============================================================
ATTIO_API_KEY=your_attio_api_key_here


# ============================================================
# GMAIL — Reply Monitoring via Gmail API (Optional)
# Alternative to Instantly for inbox monitoring.
# Setup: https://console.cloud.google.com → APIs → Gmail API
# ============================================================
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here


# ============================================================
# BOUNCE THRESHOLDS (used by List Builder for quality checks)
# Expressed as decimals (0.03 = 3%)
# ============================================================
MAX_BOUNCE_RATE_THRESHOLD=0.03
MAX_CATCHALL_PERCENTAGE=0.20


# ============================================================
# GOOGLE SLIDES / DRIVE — Deck and Document Publishing
# Used by: .claude/skills/google-slides/ scripts
# Setup: Google Cloud Console → service account → .google-credentials.json
# ============================================================
GOOGLE_CREDENTIALS_PATH=.google-credentials.json

# EmailShepherd Drive folders (run setup_es_folders.py to create and get IDs)
EMAILSHEPHERD_DRIVE_FOLDER_ID=your_shared_drive_root_folder_id
EMAILSHEPHERD_DECKS_FOLDER_ID=your_decks_subfolder_id
EMAILSHEPHERD_DOCUMENTS_FOLDER_ID=your_documents_subfolder_id
EMAILSHEPHERD_CASE_STUDIES_FOLDER_ID=your_case_studies_subfolder_id


# ============================================================
# GMAIL - Website Lead Magnet Emails
# Used by: clients/self/website/api/server.py
# Setup: Google Account > Security > App Passwords
# ============================================================
GMAIL_ADDRESS=will@leadershipgrowthconsulting.com
GMAIL_APP_PASSWORD=your-app-password-here


# ============================================================
# SUPABASE — Blog CMS Database
# Used by: blog.html, admin.html, api/blog.py, publish_article.py
# Setup: https://supabase.com → New Project → Settings → API
# ============================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here


# ============================================================
# UNSPLASH — Blog Cover Images (Primary)
# Used by: fetch_cover_image.py, Writer agent
# Get your key at: https://unsplash.com/developers → New Application
# ============================================================
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here


# ============================================================
# PEXELS — Blog Cover Images (Fallback)
# Used by: fetch_cover_image.py
# Get your key at: https://www.pexels.com/api/ → Your API Key
# ============================================================
PEXELS_API_KEY=your_pexels_api_key_here


# ============================================================
# GOOGLE MAPS — Local Business Discovery
# Used by: Outreach system (discover.ts)
# Setup: Google Cloud Console → APIs → Places API (New) → API Key
# Free tier: 10,000 requests/month
# ============================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# ============================================================
# COMPANIES HOUSE — UK Company Verification
# Used by: Outreach system (qualify.ts)
# Setup: https://developer.company-information.service.gov.uk/
# Free, rate-limited to 600 requests per 5 minutes
# ============================================================
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key_here


# ============================================================
# YOUTUBE DATA API — Outlier Content Finder
# Used by: .claude/skills/find-outlier-content/scripts/outlier_finder.py
# Setup: Google Cloud Console → APIs → YouTube Data API v3 → API Key
# Free tier: 10,000 units/day (more than enough)
# ============================================================
YOUTUBE_API_KEY=your_youtube_api_key_here


# ============================================================
# GENERAL API KEYS (existing - keep as needed)
# ============================================================
# OPENAI_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here
# NOTION_API_KEY=
# AIRTABLE_API_KEY=
# SLACK_WEBHOOK_URL=
